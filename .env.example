# Server
PORT=4173
PUBLIC_BASE_URL=http://localhost:4173
ENABLE_WORKER=false
AUTOMATION_INTERVAL_MS=60000
WORKER_LEASE_MS=180000
AUTONOMY_MODE=false
AUTONOMY_INTERVAL_MS=21600000
AUTONOMY_MAX_SCRIPTS_PER_RUN=3
AUTONOMY_MAX_OFFERS_PER_RUN=3
AUTONOMY_MAX_CYCLES_PER_DAY=8
AUTONOMY_MAX_CREATED_POSTS_PER_DAY=24
AUTONOMY_MAX_QUEUE_DEPTH=50
AUTONOMY_MAX_FAILED_RUNS=3
AUTONOMY_MAX_BLOCKED_SCRIPTS_PER_DAY=6
CONTENT_FRESHNESS_LOOKBACK_DAYS=14
CONTENT_SIMILARITY_THRESHOLD=0.88
AD_INTELLIGENCE_FEED_URLS=
AFFILIATE_OFFER_FEED_URLS=
AD_INTELLIGENCE_MAX_ITEMS=24
AD_INTELLIGENCE_TIMEOUT_MS=8000
META_GRAPH_BASE=https://graph.facebook.com/v25.0
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_QUERY=
META_AD_LIBRARY_COUNTRIES=US
META_AD_LIBRARY_AD_TYPE=ALL
META_AD_LIBRARY_LIMIT=10
CONVERSION_WEBHOOK_SECRET=
DATABASE_URL=
DATABASE_AUTO_MIGRATE=true
DATABASE_SSL=false

# Threads API
# Official docs currently allow graph.threads.net and graph.threads.com.
THREADS_GRAPH_BASE=https://graph.threads.net/v1.0
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_DRY_RUN=true
THREADS_PUBLISH_DELAY_MS=30000

# AI draft generation
# openai = OpenAI Responses API; template = local deterministic fallback
AI_DRAFT_PROVIDER=openai
PROFIT_SCRIPT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# Affiliate defaults
DEFAULT_DISCLOSURE_TEXT=含聯盟連結
DEFAULT_UTM_SOURCE=threads
DEFAULT_UTM_MEDIUM=affiliate_social
